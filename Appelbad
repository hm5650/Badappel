local function getContentFetcher()
	if syn and syn.request then return syn.request end
	if http and http.request then return http.request end
	if http_request then return http_request end
	if fluxus and fluxus.request then return fluxus.request end
	if request then return request end
	return nil
end
local function start()
	pcall(function()
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "good apple when?",
			Text = "belh",
			Duration = 3
		})
	end)
	local running = true
	local music = nil
	task.spawn(executeFadeInAnimation)
	local function performUltimateDestruction()
		if not running then return end
		running = false
		if music then
			music:Stop()
			music:Destroy()
			music = nil
		end
		if cameraConnection then cameraConnection:Disconnect() end
		if ControlScreenGui then ControlScreenGui:Destroy() end
		if floatingPart then floatingPart:Destroy() end
		task.spawn(function()
			if #idk > 0 then
				local selectedId = idk[math.random(1, #idk)]
				local memeSound = Instance.new("Sound")
				memeSound.SoundId = selectedId
				memeSound.Volume = 0.8
				memeSound.Parent = SoundService
				memeSound:Play()
				memeSound.Ended:Connect(function()
					memeSound:Destroy()
				end)
			end
		end)
		local detraBoom = Instance.new("Sound")
		detraBoom.SoundId = y
		detraBoom.Volume = 1
		detraBoom.Parent = SoundService
		detraBoom:Play()
		task.spawn(function()
			detraBoom.Ended:Connect(function()
				detraBoom:Destroy()
			end)
		end)
		ScreenFlash.Visible = true
		ScreenFlash.BackgroundTransparency = 0
		ExplosionOverlay.Visible = true
		ExplosionOverlay.ImageTransparency = 0.5
		ExplosionOverlay.Size = UDim2.new(0, 200, 0, 200)
		local flashTween = TweenService:Create(ScreenFlash, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
		local boomTween = TweenService:Create(ExplosionOverlay, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, 850, 0, 850),
			ImageTransparency = 0.2
		})
		flashTween:Play()
		boomTween:Play()
		task.wait(0.6)
		local fadeOutBoom = TweenService:Create(ExplosionOverlay, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			ImageTransparency = 1,
			Size = UDim2.new(0, 1200, 0, 1200)
		})
		fadeOutBoom:Play()
		task.wait(0.5)
		if OverlaysGui then
			OverlaysGui:Destroy()
		end
	end
	DestroyButton.MouseButton1Click:Connect(performUltimateDestruction)
	billboard.Destroying:Connect(function()
		if running then
			performUltimateDestruction()
		end
	end)
	local grabContent = getContentFetcher()
	if not grabContent or not writefile or not getcustomasset then
		gui["TextLabel_4"].Text = "Unsupported executor"
		return
	end
	local statusText = gui["TextLabel_4"]
	local screen = gui["AsciiDisplay"]
	local CHUNK_SOURCE = "https://raw.githubusercontent.com/MINEOGO/bad-apple-ascii/main/chunks/chunk_%d.txt"
	local MUSIC_SOURCE = "https://github.com/MINEOGO/bad-apple-ascii/raw/refs/heads/main/Bad%20Apple__%20.mp3"
	local MUSIC_FILE = "bad_apple_audio.mp3"
	local DELIMITER = "[FRAME_BREAK]"
	local FRAME_COUNT = 6571
	local CHUNK_SIZE = 100
	local TOTAL_CHUNKS = math.ceil(FRAME_COUNT / CHUNK_SIZE)
	local FPS_TARGET = 40
	local FRAME_DELAY = 1 / FPS_TARGET
	local thisChunk = nil
	local nextChunk = nil
	local musicID = nil
	local chunkNum = 0
	local function grabChunk(chunkIndex)
		local url = string.format(CHUNK_SOURCE, chunkIndex)
		local success, response = pcall(grabContent, { Url = url, Method = "GET" })
		if success and response and response.StatusCode == 200 then
			return string.split(response.Body or response.body or "", DELIMITER)
		end
		return nil
	end
	task.spawn(function()
		statusText.Text = "Downloading assets..."
		task.spawn(function()
			local success, response = pcall(grabContent, { Url = MUSIC_SOURCE, Method = "GET" })
			if success and response and response.StatusCode == 200 then
				writefile(MUSIC_FILE, response.Body or response.body)
				musicID = getcustomasset(MUSIC_FILE)
			end
		end)
		thisChunk = grabChunk(1)
		while (not thisChunk or not musicID) and running do
			statusText.Text = string.format("Loading... (Audio: %s | Video: %s)",
				musicID and "OK" or "...",
				thisChunk and "OK" or "...")
			task.wait(0.1)
		end
		if not running then return end
		if not thisChunk or not musicID then
			statusText.Text = "Asset download failed."
			return
		end
		chunkNum = 1
		music = Instance.new("Sound")
		music.SoundId = musicID
		music.Parent = SoundService
		music:Play()
		task.spawn(function()
			if chunkNum < TOTAL_CHUNKS then
				nextChunk = grabChunk(chunkNum + 1)
			end
		end)
		for i = 1, FRAME_COUNT do
			if not running then break end
			local startTime = tick()
			local expectedChunk = math.ceil(i / CHUNK_SIZE)
			if expectedChunk > chunkNum then
				while not nextChunk and running do
					statusText.Text = "Waiting for next chunk..."
					task.wait()
				end
				if not nextChunk then break end
				thisChunk = nextChunk
				nextChunk = nil
				chunkNum = expectedChunk
				if chunkNum < TOTAL_CHUNKS then
					task.spawn(function()
						nextChunk = grabChunk(chunkNum + 1)
					end)
				end
			end
			local indexInChunk = i - ((chunkNum - 1) * CHUNK_SIZE)
			if thisChunk and thisChunk[indexInChunk] then
				screen.Text = thisChunk[indexInChunk]
			end
			local currentFps = 1 / (tick() - startTime)
			statusText.Text = string.format("Playing: %d/%d | FPS: %.0f", i, FRAME_COUNT, currentFps)
			local elapsedTime = tick() - startTime
			local timeToWait = FRAME_DELAY - elapsedTime
			if timeToWait > 0 then
				task.wait(timeToWait)
			end
		end
		if running then
			statusText.Text = "Finished."
		end
	end)
end
